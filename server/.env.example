# ===== LLM 提供商配置 =====
# 智谱 AI（免费主力）
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 魔搭 ModelScope
MODELSCOPE_API_KEY=
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# ===== 数据库 =====
# Railway PostgreSQL 连接串（未配置时自动降级到内存存储）
DATABASE_URL=

# ===== 服务配置 =====
PORT=3001
# 允许的跨域来源，逗号分隔
CORS_ORIGIN=http://localhost:5173,https://yance-bagua-engine.surge.sh
