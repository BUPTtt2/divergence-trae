# 演策前端环境变量示例
# 复制为 .env / .env.development / .env.production 按需修改

# 后端 API 地址（Cloudflare Workers 部署后替换）
# 本地开发可用 wrangler dev 提供的地址：http://localhost:8787
VITE_API_BASE=http://localhost:8787

# JWT 签名密钥（与后端 wrangler secret JWT_SECRET 保持一致）
# 仅用于前端 fallback 签名，主签名由后端完成
VITE_SIGNING_SECRET=change_this_in_production

# 应用版本号
VITE_APP_VERSION=1.3.0
